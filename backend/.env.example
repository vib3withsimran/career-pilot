# =============================================================================
# CAREER PILOT - BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit your .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# Port the backend server listens on
# Type: number
PORT=5000

# Runtime environment - controls logging, error detail, and optimizations
# Type: string | values: development | staging | production
NODE_ENV=development

# URL of the frontend app - used for CORS allow-list
# Type: string (URL)
FRONTEND_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# DATABASE - MONGODB
# -----------------------------------------------------------------------------

# MongoDB connection string (local or Atlas)
# Type: string (URI)
# Atlas format: mongodb+srv://<user>:<password>@cluster.mongodb.net/career-pilot
MONGODB_URI=mongodb://localhost:27017/career-pilot

# Enable slow-query logging - set to true only in dev/staging, never in production
# Type: boolean
ENABLE_DB_PROFILING=false


# -----------------------------------------------------------------------------
# FIREBASE ADMIN SDK
# -----------------------------------------------------------------------------

# Firebase project ID (found in Firebase Console > Project Settings)
# Type: string
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Firebase Storage bucket name
# Type: string
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket.appspot.com

# Path to downloaded service account JSON key file
# Type: string (file path)
# Download from: Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/service-account-key.json


# -----------------------------------------------------------------------------
# AI SERVICES
# -----------------------------------------------------------------------------

# Google Gemini API key - used for resume enhancement and AI interviews
# Type: string
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key - used as a fast inference alternative
# Type: string
# Get from: https://console.groq.com
GROQ_API_KEY=GROQ_API_KEY=your_groq_api_key_here


# -----------------------------------------------------------------------------
# JOB SEARCH - RAPIDAPI
# -----------------------------------------------------------------------------

# RapidAPI key for the JSearch job listings API
# Type: string
# Get from: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# RapidAPI host for the job search endpoint
# Type: string
RAPIDAPI_HOST=jsearch.p.rapidapi.com


# -----------------------------------------------------------------------------
# EMAIL - NODEMAILER
# -----------------------------------------------------------------------------

# Sender address for job alert emails
# Type: string (email)
EMAIL_USER=no-reply@example.com

# SMTP password or app-specific password
# Type: string
EMAIL_PASS=your_gmail_app_password_here

# SMTP server hostname
# Type: string
EMAIL_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL)
# Type: number
EMAIL_PORT=587

# External email microservice URL (used in staging/production)
# Type: string (URL)
EMAIL_SERVICE_URL=https://email-service.example.com

# API key to authenticate requests to the email microservice
# Type: string
EMAIL_API_KEY=your_email_api_key_here


# -----------------------------------------------------------------------------
# REDIS - JOB QUEUE (BULLMQ)
# -----------------------------------------------------------------------------

# Redis connection URL - used by BullMQ for background job processing
# Type: string (URI)
# Upstash format: rediss://:password@host:port
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Time window for rate limiting in milliseconds (default: 15 minutes)
# Type: number
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests allowed per window per IP
# Type: number
RATE_LIMIT_MAX_REQUESTS=100


# -----------------------------------------------------------------------------
# JOB ALERT SCHEDULER
# -----------------------------------------------------------------------------

# Cron schedule for running job alert checks (default: every 6 hours)
# Type: string (cron expression)
ALERT_CRON_SCHEDULE="0 */6 * * *"

# Override interval in ms for testing alerts locally - leave empty in production
# Type: number | leave blank to disable
ALERT_TEST_INTERVAL=

# LinkedIn Importer — Proxycurl API (https://proxycurl.com)
# Free tier: 10 credits. Paid: ~$0.01/profile.
PROXYCURL_API_KEY=your_proxycurl_api_key
# DB query profiling — set to true only in dev/staging to enable slow-query logging
ENABLE_DB_PROFILING=false

# -----------------------------------------------------------------------------
# PAYMENTS - RAZORPAY
# -----------------------------------------------------------------------------

# Razorpay Key ID - use rzp_test_ prefix for test mode
# Type: string
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Razorpay Key Secret - keep this strictly server-side, never expose to frontend
# Type: string
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here


# -----------------------------------------------------------------------------
# LINKEDIN OAUTH
# -----------------------------------------------------------------------------

# LinkedIn OAuth App Client ID
# Type: string
# Register at: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here

# LinkedIn OAuth App Client Secret
# Type: string
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# Redirect URI registered in LinkedIn app settings
# Type: string (URL)
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/linkedin/callback


# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------

# 64-character hex key used to encrypt TOTP secrets
# Type: string (64-char hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=your_totp_encryption_key_here


# -----------------------------------------------------------------------------
# PORTFOLIO DEPLOYMENT - CLOUDFLARE PAGES
# -----------------------------------------------------------------------------

# Cloudflare API token with "Cloudflare Pages: Edit" permission
# Type: string
# Create at: https://dash.cloudflare.com/profile/api-tokens
#   → Create Token → Edit Cloudflare Pages (template)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare Account ID — found in the right sidebar of any zone/dashboard page
# Type: string
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Shared secret used to verify HMAC-SHA256 signatures on deployment webhook events.
# Set this to a strong random string and configure the same value in your
# Cloudflare Notifications webhook URL settings.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Type: string
CLOUDFLARE_WEBHOOK_SECRET=your_cloudflare_webhook_secret_here


# -----------------------------------------------------------------------------
# PORTFOLIO DEPLOYMENT - GITHUB PAGES
# -----------------------------------------------------------------------------

# GitHub OAuth App Client ID — used to initiate the OAuth flow so users can
# grant Career Pilot permission to create and manage their portfolio repos.
# Type: string
# Register at: https://github.com/settings/applications/new
#   - Authorization callback URL: http://localhost:5000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here

# GitHub OAuth App Client Secret
# Type: string
GITHUB_CLIENT_SECRET=your_github_client_secret_here


# -----------------------------------------------------------------------------
# PORTFOLIO DEPLOYMENT - NETLIFY
# -----------------------------------------------------------------------------

# Personal access token for the Netlify API
# Type: string
# Generate at: https://app.netlify.com/user/applications#personal-access-tokens
# Note: Each user can supply their own token per request; this value is the
#       server-owned fallback used when no per-request token is provided.
NETLIFY_ACCESS_TOKEN=your_netlify_personal_access_token_here


# -----------------------------------------------------------------------------
# LOCAL DEVELOPMENT ONLY - never set these to true in production
# -----------------------------------------------------------------------------

# Bypass Firebase auth verification for local testing
# Type: boolean
DEV_BYPASS_AUTH=false

# UID to use when auth bypass is enabled
# Type: string
DEV_USER_UID=dev-user-001

# Email to use when auth bypass is enabled
# Type: string (email)
DEV_USER_EMAIL=dev@example.com